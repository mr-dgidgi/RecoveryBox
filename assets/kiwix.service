[Unit]
Description=Kiwix Offline Server Container
After=docker.service
Requires=docker.service

[Service]
Restart=always
RestartSec=3
ExecStartPre=docker rm -f kiwix-serve 2>/dev/null
ExecStart=/usr/bin/docker run -rm --name kiwix-serve \
  -p 80:8080 \
  -v /data/kiwix:/data \
  ghcr.io/kiwix/kiwix-serve:3.8.2 \
  sh -c "kiwix-serve *.zim"

ExecStop=/usr/bin/docker stop kiwix-serve

[Install]
WantedBy=multi-user.target